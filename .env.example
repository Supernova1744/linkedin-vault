# LinkedIn Vault Configuration

# LLM Provider: zai (cloud) or ollama (local)
LLM_PROVIDER=zai
LLM_MODEL=glm-4-flash

# z.ai API (https://api.z.ai)
ZAI_API_KEY=your_api_key_here

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434

# Dashboard
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8765

# Optional: custom DB path (default: ~/.linkedin-vault/vault.db)
# DB_PATH=/path/to/vault.db
